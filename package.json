{
  "name": "caldav-to-ics",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "flask-dev": "uv venv --quiet 2>/dev/null; uv pip install -r requirements.txt && FLASK_DEBUG=1 uv run python -m flask --app api/sync run -p 5328",
    "next-dev": "next dev",
    "dev": "concurrently \"pnpm run next-dev\" \"pnpm run flask-dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "concurrently": "^9.2.1",
    "@vercel/blob": "^2.3.1"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp"]
  }
}
